# XBuddy environment configuration
# Copy this file to .env and fill in your values

# ========== LLM API Keys (at least one required) ==========
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-key

# ========== Server ==========
HOST=0.0.0.0
PORT=8080

# ========== Database ==========
# Default: SQLite (no setup needed)
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=/tmp/xbuddy_checkpoints.db

# ========== LangSmith (recommended) ==========
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=xbuddy

# ========== Supabase (optional — needed for PR 4+) ==========
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key

# ========== Auth (optional) ==========
# AUTH_SECRET=your-secret-token
